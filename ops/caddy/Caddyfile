{
	admin 127.0.0.1:2019
	auto_https disable_redirects
}

https://clideck-mcp.lan {
	tls internal

	@trusted_lan remote_ip 127.0.0.1/32 ::1/128 10.11.5.0/24 fd00::/8
	handle @trusted_lan {
		reverse_proxy 127.0.0.1:8790 {
			header_up Host {host}
			header_up X-Forwarded-Proto https
		}
	}

	handle {
		respond "LAN access only" 403
	}

	log {
		output file /var/log/caddy/clideck-mcp-admin-access.log {
			roll_size 10MiB
			roll_keep 5
		}
		format filter {
			wrap json
			fields {
				request>headers>Cookie delete
				request>headers>Authorization delete
			}
		}
	}
}
