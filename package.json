{
  "name": "clideck-mcp",
  "version": "0.7.2",
  "private": true,
  "description": "Agent-native framework for verified, continuously updated MCP knowledge systems",
  "type": "module",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm domain:build && pnpm contracts:build && tsc -p tsconfig.build.json && pnpm admin:build",
    "check": "pnpm domain:check && pnpm contracts:build && tsc -p tsconfig.json --noEmit && pnpm admin:check",
    "domain:build": "pnpm -r --filter '@clideck/domain-*' build",
    "domain:check": "pnpm domain:build && pnpm -r --filter '@clideck/domain-*' check",
    "domain:create": "tsx src/cli/create-domain.ts",
    "domain:validate": "tsx src/cli/validate-domain.ts",
    "domain:seed-engineering": "tsx src/cli/seed-engineering-measurements.ts",
    "contracts:build": "pnpm --filter @clideck/admin-contracts build",
    "admin:build": "pnpm --filter @clideck/admin-ui build",
    "admin:check": "pnpm --filter @clideck/admin-ui check",
    "admin:dev": "pnpm --filter @clideck/admin-ui dev",
    "demo:build": "pnpm admin:build",
    "demo:check": "pnpm --filter @clideck/admin-ui check",
    "demo:dev": "pnpm --filter @clideck/admin-ui dev",
    "admin:setup": "tsx src/cli/setup-admin.ts",
    "dev:api": "tsx watch src/entrypoints/api.ts",
    "dev:researcher": "tsx watch src/entrypoints/researcher.ts",
    "dev:worker": "tsx watch src/entrypoints/worker.ts",
    "start:api": "node dist/entrypoints/api.js",
    "start:admin": "node dist/entrypoints/admin.js",
    "start:researcher": "node dist/entrypoints/researcher.js",
    "start:worker": "node dist/entrypoints/worker.js",
    "db:migrate": "tsx src/cli/migrate.ts",
    "db:seed": "tsx src/cli/seed.ts",
    "eval": "tsx src/cli/eval.ts",
    "legacy:export": "tsx src/cli/export-legacy.ts",
    "legacy:import": "tsx src/cli/import-legacy.ts",
    "lab:check-runtime": "tsx src/cli/check-runtime-lab.ts",
    "lab:build-report": "tsx src/cli/build-lab-report.ts",
    "lab:import-report": "tsx src/cli/import-lab-report.ts",
    "researcher:claim": "node --env-file=.secrets/researcher-bridge.env --import tsx src/cli/researcher-client.ts claim",
    "researcher:heartbeat": "node --env-file=.secrets/researcher-bridge.env --import tsx src/cli/researcher-client.ts heartbeat",
    "researcher:submit": "node --env-file=.secrets/researcher-bridge.env --import tsx src/cli/researcher-client.ts submit",
    "researcher:fail": "node --env-file=.secrets/researcher-bridge.env --import tsx src/cli/researcher-client.ts fail",
    "pipeline:coordinator": "node --env-file=.secrets/researcher-bridge.env --import tsx src/cli/pipeline-coordinator.ts",
    "pipeline:pool": "node --env-file=.secrets/researcher-bridge.env --import tsx src/cli/pipeline-pool.ts",
    "pipeline:pool-start": "tsx src/cli/control-pipeline-launchd.ts start",
    "pipeline:pool-stop": "tsx src/cli/control-pipeline-launchd.ts stop",
    "pipeline:pool-status": "tsx src/cli/control-pipeline-launchd.ts status",
    "pipeline:install-launchd": "tsx src/cli/install-pipeline-launchd.ts",
    "pipeline:claim": "node --env-file=.secrets/researcher-bridge.env --import tsx src/cli/pipeline-client.ts claim",
    "pipeline:task": "node --env-file=.secrets/researcher-bridge.env --import tsx src/cli/pipeline-client.ts task",
    "pipeline:heartbeat": "node --env-file=.secrets/researcher-bridge.env --import tsx src/cli/pipeline-client.ts heartbeat",
    "pipeline:submit-discovery": "node --env-file=.secrets/researcher-bridge.env --import tsx src/cli/pipeline-client.ts submit-discovery",
    "pipeline:submit-analysis": "node --env-file=.secrets/researcher-bridge.env --import tsx src/cli/pipeline-client.ts submit-analysis",
    "pipeline:submit-verification": "node --env-file=.secrets/researcher-bridge.env --import tsx src/cli/pipeline-client.ts submit-verification",
    "pipeline:submit-deep-review": "node --env-file=.secrets/researcher-bridge.env --import tsx src/cli/pipeline-client.ts submit-deep-review",
    "pipeline:submit-expert": "node --env-file=.secrets/researcher-bridge.env --import tsx src/cli/pipeline-client.ts submit-expert",
    "test": "vitest run && pnpm -r --filter '@clideck/domain-*' test && pnpm --filter @clideck/admin-ui test",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clideck/domain-kit": "workspace:*",
    "@clideck/domain-engineering-measurements": "workspace:*",
    "@clideck/domain-network": "workspace:*",
    "@clideck/admin-contracts": "workspace:*",
    "@hono/node-server": "2.0.10",
    "@modelcontextprotocol/sdk": "1.29.0",
    "hono": "4.12.30",
    "pg": "8.22.0",
    "pino": "9.14.0",
    "prom-client": "15.1.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.10.4",
    "@types/pg": "8.16.0",
    "tsx": "4.21.0",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
